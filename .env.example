# Render / local deployment example
# If this value is set, the app will use Supabase Postgres.
# If it is missing, the app will keep using the local SQLite file orders.db.

SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
PGSSLMODE=require
